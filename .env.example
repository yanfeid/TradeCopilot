# ---- Analysis provider ----
# How the "Analyze" tab talks to Claude:
#   claude_cli  (default) -> uses your Claude Code SUBSCRIPTION via the local
#                            `claude` CLI. No API key, no per-token API billing.
#                            Just make sure `claude` is installed and logged in.
#   api                   -> uses the Anthropic API and ANTHROPIC_API_KEY below.
ANALYSIS_PROVIDER=claude_cli

# Optional: force a model for the CLI (subscription). Leave blank to use your
# subscription's default model.
CLAUDE_MODEL=

# ---- Only needed if ANALYSIS_PROVIDER=api ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
